# --- Vercel / runtime ---
# TELEGRAM_BOT_TOKEN и SESSION_SECRET должны быть доступны в той же среде, что и деплой:
# Production И Preview (удобно: Environment = "All"), иначе токен «есть в UI», но в runtime пустой.
# После добавления/смены переменных обязателен Redeploy.
# NEXT_PUBLIC_* попадают в клиентский бандл; TELEGRAM_BOT_TOKEN — только сервер (API routes / server actions).

# Local Postgres (see docker-compose.yml) or Neon/Supabase on Vercel
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sakbol?schema=public"
# Локально: docker compose up -d →  npm run db:local  (migrate + seed)
# В development первый вход /api/auth/dev может сам создать Demo Admin, если БД пуста (после migrate).

# После seed: веб-вход /login → «Email и пароль». В production задайте свой пароль (не коммитьте).
# SEED_ADMIN_EMAIL="admin@sakbol.demo"
# SEED_ADMIN_PASSWORD=""

# Webhook привязки Telegram (/start КОД) и внутренний API бота:
# TELEGRAM_WEBHOOK_SECRET=""
# Секрет для POST /api/internal/telegram-set-webhook и GET /api/internal/bot/profile
# BOT_INTERNAL_SECRET=""

# HMAC for Telegram Web App initData (BotFather)
TELEGRAM_BOT_TOKEN=""
# Если сервер не может достучаться до api.telegram.org (например, блокировки в РФ),
# укажите базовый URL вашего прокси Telegram Bot API (без завершающего /):
# TELEGRAM_API_BASE_URL="https://your-telegram-proxy.example"
# Для скачивания файлов можно задать отдельную базу, иначе используется ${TELEGRAM_API_BASE_URL}/file:
# TELEGRAM_FILE_BASE_URL="https://your-telegram-proxy.example/file"

# Signing session cookie (use a long random string in production)
SESSION_SECRET="change-me-to-at-least-16-chars"

# HMAC-якорь ПИН/ИНН (КР): не короче 16 символов (ниже — пример ровно из 16); в production — свой случайный секрет.
PIN_ANCHOR_PEPPER="sakbol-pin-16xx!"

# Локально: демо-вход только по явной кнопке на /login (больше нет авто-входа из браузера).
ALLOW_DEV_LOGIN="true"
# Показать кнопку dev-кирүү на /login (клиент)
NEXT_PUBLIC_ALLOW_DEV_LOGIN="true"

# Имя бота без @ — ссылка «Telegram аркылуу кирүү» на /login (опционально: QR подтянет username через getMe)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# Сборка без migrate (Vercel/CI без БД): 1 — только prisma generate + next build
# SKIP_PRISMA_MIGRATE_ON_BUILD="1"

# Базовый URL для scripts/set-telegram-webhook.ts (с протоколом, без слэша в конце)
# WEBHOOK_BASE_URL="https://adventory.store"

# --- Свой сервер (Docker + nginx, см. docs/SELF_HOSTED.md) ---
# Публичный origin (обязательно с https://) — ссылки в Telegram и getServerAppOrigin()
# NEXT_PUBLIC_APP_URL="https://adventory.store"
# APP_URL="https://adventory.store"
#
# docker-compose.selfhosted.yml подставляет DATABASE_URL на контейнер `web` сам; для интерполяции compose нужен пароль БД:
# POSTGRES_PASSWORD="сгенерируйте-длинный-пароль"
# POSTGRES_USER="sakbol"
# POSTGRES_DB="sakbol"
#
# Файлы на диске VPS (volume). В compose уже задано /data/sakbol
# SAKBOL_DATA_DIR="/data/sakbol"
#
# Почасовой cron вместо vercel.json: curl с Bearer (см. SELF_HOSTED.md)
# CRON_SECRET=""

# Прод: автоматический вход под dev Admin в обычном браузере (не Telegram). Опасно для публичного URL без защиты.
# AUTO_DEV_ADMIN_IN_BROWSER="true"

# Только для локальных тестов: подставлять случайный мок вместо API (не для продакшена).
# ALLOW_MOCK_LAB_PARSER="1"

# --- ИИ (рекомендуемый минимум: OpenRouter + при желании DeepSeek) ---
# OpenRouter: достаточно OPENROUTER_API_KEY — чат/перевод (Gemma 4 31B free), OCR PDF и фото бланков (Nemotron 3 Nano Omni free).
# Явно выключить: OPENROUTER_DISABLED="1" или OPENROUTER_ENABLED="0".
# OPENROUTER_API_KEY=""
# OPENROUTER_CHAT_MODEL="google/gemma-4-31b:free"
# OPENROUTER_REASONING_MODEL="google/gemma-4-31b:free"
# OPENROUTER_OCR_MODEL="nvidia/nemotron-3-nano-omni:free"
# OPENROUTER_VISION_MODEL="nvidia/nemotron-3-nano-omni:free"
# OPENROUTER_DATA_RETENTION="deny"
# OPENROUTER_HTTP_REFERER="https://adventroy.store"
# OPENROUTER_APP_TITLE="SakBol"
# OPENROUTER_TIMEOUT_MS="120000"

# DeepSeek — резерв после OpenRouter (чат, перевод документов, PDF с извлечённым текстом).
# DEEPSEEK_API_KEY=""
# DEEPSEEK_MODEL="deepseek-v4-pro"
# DEEPSEEK_TIMEOUT_MS="60000"
# DEEPSEEK_TRANSLATE_TIMEOUT_MS="120000"

# Опционально: один провайдер вкладки «ИИ» вместо цепочки OpenRouter → DeepSeek:
# LAB_ASSISTANT_PROVIDER="openai" | "bedrock" | "gemini" | "anthropic" | "deepseek"
# Другие облачные ключи (Gemini, OpenAI, Anthropic, AWS Bedrock) не перечислены здесь — см. код и docs при необходимости.

# Секрет для POST /api/documents/upload-automated (Python / автоматизация). В production обязателен.
# Передавайте заголовок: Authorization: Bearer <secret> или x-documents-secret: <secret>
# DOCUMENTS_AUTOMATION_SECRET=""
# Только чисто локальный next dev (без VERCEL=1): разрешить automated без секрета — не включать в Preview/Production.
# ALLOW_INSECURE_AUTOMATED_UPLOAD="true"

# Vercel Blob: без токена файлы health-доков и **лаб-анализов** не переживут serverless/шаринг — см. BLOB в Dashboard.
# На своём VPS обычно не нужен: оставьте пустым — файлы пишутся в SAKBOL_DATA_DIR.
# BLOB_READ_WRITE_TOKEN=""

# Стабильный 32-байтовый ключ (base64) для Server Actions Next.js 15.
# Без него каждый redeploy ломает уже открытые сессии: "Server Action ... was not found".
# Сгенерировать один раз: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""
