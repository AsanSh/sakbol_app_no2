# Local Postgres (see docker-compose.yml) or Neon/Supabase on Vercel
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sakbol?schema=public"
# After pulling: npx prisma migrate deploy (or db push in dev)

# HMAC for Telegram Web App initData (BotFather)
TELEGRAM_BOT_TOKEN=""

# Signing session cookie (use a long random string in production)
SESSION_SECRET="change-me-to-at-least-16-chars"

# Browser / Vercel demo: set both to "true" so the app works outside Telegram (uses first ADMIN from DB after seed)
ALLOW_DEV_LOGIN="false"
NEXT_PUBLIC_ALLOW_DEV_LOGIN="false"

# Optional: real vision parsing (otherwise mock)
OPENAI_API_KEY=""
