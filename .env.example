# --- Vercel / runtime ---
# TELEGRAM_BOT_TOKEN и SESSION_SECRET должны быть доступны в той же среде, что и деплой:
# Production И Preview (удобно: Environment = "All"), иначе токен «есть в UI», но в runtime пустой.
# После добавления/смены переменных обязателен Redeploy.
# NEXT_PUBLIC_* попадают в клиентский бандл; TELEGRAM_BOT_TOKEN — только сервер (API routes / server actions).

# Local Postgres (see docker-compose.yml) or Neon/Supabase on Vercel
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sakbol?schema=public"
# Локально: docker compose up -d →  npm run db:local  (migrate + seed)
# В development первый вход /api/auth/dev может сам создать Demo Admin, если БД пуста (после migrate).

# После seed: веб-вход /login → «Email и пароль». В production задайте свой пароль (не коммитьте).
# SEED_ADMIN_EMAIL="admin@sakbol.demo"
# SEED_ADMIN_PASSWORD=""

# Webhook привязки Telegram (/start КОД) и внутренний API бота:
# TELEGRAM_WEBHOOK_SECRET=""
# BOT_INTERNAL_SECRET=""

# HMAC for Telegram Web App initData (BotFather)
TELEGRAM_BOT_TOKEN=""

# Signing session cookie (use a long random string in production)
SESSION_SECRET="change-me-to-at-least-16-chars"

# HMAC-якорь ПИН/ИНН (КР): не короче 16 символов (ниже — пример ровно из 16); в production — свой случайный секрет.
PIN_ANCHOR_PEPPER="sakbol-pin-16xx!"

# Локально: демо-вход только по явной кнопке на /login (больше нет авто-входа из браузера).
ALLOW_DEV_LOGIN="true"
# Показать кнопку dev-кирүү на /login (клиент)
NEXT_PUBLIC_ALLOW_DEV_LOGIN="true"

# Имя бота без @ — ссылка «Telegram аркылуу кирүү» на /login
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# Прод: автоматический вход под dev Admin в обычном браузере (не Telegram). Опасно для публичного URL без защиты.
# AUTO_DEV_ADMIN_IN_BROWSER="true"

# Распознавание бланков: Gemini (PDF + изображения). Без ключа загрузка анализа вернёт ошибку.
GEMINI_API_KEY=""
# Явно задать модель из AI Studio, если автоперебор не подходит: https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL="gemini-2.5-flash"

# Только для локальных тестов: подставлять случайный мок вместо API (не для продакшена).
# ALLOW_MOCK_LAB_PARSER="1"

OPENAI_API_KEY=""

# Секрет для POST /api/documents/upload-automated (Python / автоматизация). В production обязателен.
# Передавайте заголовок: Authorization: Bearer <secret> или x-documents-secret: <secret>
# DOCUMENTS_AUTOMATION_SECRET=""
# Только чисто локальный next dev (без VERCEL=1): разрешить automated без секрета — не включать в Preview/Production.
# ALLOW_INSECURE_AUTOMATED_UPLOAD="true"

# Vercel Blob: без токена файлы health-доков и **лаб-анализов** не переживут serverless/шаринг — см. BLOB в Dashboard.
# BLOB_READ_WRITE_TOKEN=""
