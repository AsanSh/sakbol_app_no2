generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Household / access boundary for Family RBAC.
model Family {
  id        String    @id @default(cuid())
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profiles  Profile[]
  plan      Subscription?
}

/// Identity & family role only — no medical payload (PII kept minimal, separate from HealthRecord).
model Profile {
  id             String     @id @default(cuid())
  familyId       String
  family         Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  displayName    String
  /// Set when the person uses the Telegram Mini App; null for managed relatives.
  telegramUserId String?    @unique
  avatarUrl      String?

  /// HMAC-якорь ПИН/ИНН (КР); сырой ПИН в БД не хранится. Обязателен для всех профилей после миграции.
  pinAnchor      String?    @unique

  isManaged      Boolean    @default(false)
  familyRole     FamilyRole @default(MEMBER)

  /// For managed profiles: semantic role (child, elder, etc.).
  managedRole    ManagedRelationRole?
  dateOfBirth DateTime?
  biologicalSex  BiologicalSex @default(UNKNOWN)

  healthRecords  HealthRecord[]
  medications   Medication[]

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([familyId])
  @@index([familyId, familyRole])
}

model HealthRecord {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  /// Технические метаданные (файл, парсер, время). Клинические значения — в metrics.
  data      Json
  isPrivate Boolean  @default(false)

  /// Discriminator for API routes (e.g. lab analyses).
  kind      HealthRecordKind @default(OTHER)

  title     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shares    ShareToken[]
  metrics   HealthRecordMetrics?

  @@index([profileId])
  @@index([profileId, kind])
}

/// Только лабораторные показатели (JSON), без ФИО и документов — отдельно от identity.
model HealthRecordMetrics {
  id             String       @id @default(cuid())
  healthRecordId String       @unique
  healthRecord   HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  payload        Json

  @@index([healthRecordId])
}

model ShareToken {
  id             String      @id @default(cuid())
  token          String      @unique
  healthRecordId String
  healthRecord   HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime    @default(now())

  @@index([token, expiresAt])
}

model Medication {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  dosage     String
  timeOfDay  String
  takenToday Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([profileId, timeOfDay])
}

model Subscription {
  id        String           @id @default(cuid())
  familyId  String           @unique
  family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tier      SubscriptionTier @default(FREE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum FamilyRole {
  ADMIN
  MEMBER
}

enum ManagedRelationRole {
  CHILD
  ELDER
  OTHER
}

enum HealthRecordKind {
  LAB_ANALYSIS
  NOTE
  OTHER
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum BiologicalSex {
  UNKNOWN
  MALE
  FEMALE
}
