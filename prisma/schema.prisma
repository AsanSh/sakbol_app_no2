generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Household / access boundary for Family RBAC.
model Family {
  id        String    @id @default(cuid())
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profiles  Profile[]
  plan      Subscription?
}

/// Identity & family role only — no medical payload (PII kept minimal, separate from HealthRecord).
model Profile {
  id             String     @id @default(cuid())
  familyId       String
  family         Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  displayName    String
  /// Вход с сайта без Telegram; уникален среди заполненных.
  email          String?    @unique
  /// Хеш пароля (bcrypt; legacy scrypt поддерживается на входе).
  passwordHash   String?
  /// Set when the person uses the Telegram Mini App; null for managed relatives.
  telegramUserId String?    @unique
  /// @username (нижний регистр, без @), с initData — для web OTP без getChat, если /start у бота уже был.
  telegramUsername String?  @unique
  /// Только цифры (E.164 без +) для входа на сайт по коду, если @username id не сработал.
  webLoginPhoneDigits String? @unique
  avatarUrl      String?

  /// HMAC-якорь ПИН/ИНН (КР); сырой ПИН в БД не хранится. Обязателен для всех профилей после миграции.
  pinAnchor      String?    @unique

  isManaged      Boolean    @default(false)
  familyRole     FamilyRole @default(MEMBER)

  /// For managed profiles: semantic role (child, elder, etc.).
  managedRole    ManagedRelationRole?
  dateOfBirth DateTime?
  biologicalSex  BiologicalSex @default(UNKNOWN)

  /// Антропометрия и группа крови — хранятся на сервере для синхронизации веб/Telegram.
  heightCm   Float?
  weightKg   Float?
  bloodType  String?

  /// Внешний идентификатор (например ADesk / CRM) для автозагрузки договоров и документов.
  adeskId    String?    @unique

  healthRecords  HealthRecord[]
  healthDocuments HealthDocument[]
  medications   Medication[]
  telegramLinkCodes TelegramLinkCode[]

  /// Доступы к чужим профилям, которые выданы этому профилю (он — гость).
  grantedAccesses  ProfileAccess[] @relation("AccessGrantee")
  /// Доступы к этому профилю, которые были выданы другим (этот профиль — источник).
  sharedAccesses   ProfileAccess[] @relation("AccessSource")

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([familyId])
  @@index([familyId, familyRole])
}

/// Совместный доступ: владелец одной семьи открывает конкретный профиль другой семье.
/// Сценарий: поделиться профилем мамы с братом, у которого свой аккаунт.
model ProfileAccess {
  id               String    @id @default(cuid())

  /// Профиль-источник (чьи данные расшариваются).
  sourceProfileId  String
  sourceProfile    Profile   @relation("AccessSource", fields: [sourceProfileId], references: [id], onDelete: Cascade)

  /// Профиль-гость (кому выдан доступ). Null до принятия приглашения.
  granteeProfileId String?
  grantee          Profile?  @relation("AccessGrantee", fields: [granteeProfileId], references: [id], onDelete: SetNull)

  /// Кто нажал /start share_… до регистрации в Mini App — привязка при первом входе.
  pendingTelegramUserId String?

  /// Может ли гость добавлять документы/анализы.
  canWrite         Boolean   @default(true)

  /// Одноразовый токен для QR / ссылки-приглашения.
  inviteToken      String    @unique @default(cuid())
  /// 9 цифр: ввод вручную и deep link join_… у бота / Mini App.
  inviteCode9      String?   @unique
  inviteExpiresAt  DateTime?
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([sourceProfileId])
  @@index([granteeProfileId])
  @@index([inviteToken])
  @@index([inviteCode9])
  @@index([pendingTelegramUserId])
}

/// Временный код: веб «Привязать Telegram» → пользователь /start КОД у бота.
model TelegramLinkCode {
  id         String    @id @default(cuid())
  profileId  String
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([code, expiresAt])
  @@index([profileId, createdAt])
}

model HealthRecord {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  /// Технические метаданные (файл, парсер, время). Клинические значения — в metrics.
  data      Json
  isPrivate Boolean  @default(false)

  /// Discriminator for API routes (e.g. lab analyses).
  kind      HealthRecordKind @default(OTHER)

  title     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shares    ShareToken[]
  metrics   HealthRecordMetrics?

  @@index([profileId])
  @@index([profileId, kind])
}

/// Только лабораторные показатели (JSON), без ФИО и документов — отдельно от identity.
model HealthRecordMetrics {
  id             String       @id @default(cuid())
  healthRecordId String       @unique
  healthRecord   HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  payload        Json

  @@index([healthRecordId])
}

model ShareToken {
  id             String      @id @default(cuid())
  token          String      @unique
  healthRecordId String
  healthRecord   HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime    @default(now())

  @@index([token, expiresAt])
}

/// Одноразовый код для входа с сайта (отправляется в Telegram через бота).
model WebOtpChallenge {
  id             String    @id @default(cuid())
  telegramUserId String
  codeHash       String
  expiresAt      DateTime
  consumedAt     DateTime?
  attempts       Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([telegramUserId, createdAt])
  @@index([expiresAt])
}

model Medication {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  dosage     String
  timeOfDay  String
  takenToday Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([profileId, timeOfDay])
}

model Subscription {
  id        String           @id @default(cuid())
  familyId  String           @unique
  family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tier      SubscriptionTier @default(FREE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum FamilyRole {
  ADMIN
  MEMBER
}

enum ManagedRelationRole {
  CHILD
  ELDER
  OTHER
  SPOUSE
}

enum HealthRecordKind {
  LAB_ANALYSIS
  NOTE
  OTHER
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum BiologicalSex {
  UNKNOWN
  MALE
  FEMALE
}

enum HealthDocumentCategory {
  ANALYSIS
  DISCHARGE_SUMMARY
  PROTOCOL
  PRESCRIPTION
  CONTRACT
  OTHER
}

/// «Умное хранилище»: PDF и прочие файлы вне парсинга лабораторий (договоры, выписки).
model HealthDocument {
  id           String                 @id
  profileId    String
  profile      Profile                @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title        String
  /// Публичный путь скачивания в приложении, напр. /api/documents/{id}/file
  fileUrl      String
  category     HealthDocumentCategory @default(OTHER)
  /// Дата по документу (с бланка); если null — в UI показываем createdAt.
  documentDate DateTime?
  mimeType     String?
  bytes        Int?
  /// Бинарник для скачивания без Blob/диска (serverless).
  fileData     Bytes?

  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([profileId])
  @@index([profileId, category])
  @@index([createdAt])
}
