# Пример для Ubuntu: /etc/nginx/sites-available/sakbol (продакшен: adventory.store).
# Для другого домена замените server_name и пути Let's Encrypt ниже.
# sudo ln -s /etc/nginx/sites-available/sakbol /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx

upstream sakbol_next {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name adventory.store www.adventory.store;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name adventory.store www.adventory.store;

    ssl_certificate     /etc/letsencrypt/live/adventory.store/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/adventory.store/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 15m;

    location / {
        proxy_pass http://sakbol_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 300s;
    }
}
